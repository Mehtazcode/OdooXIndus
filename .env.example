# ─── DATABASE ────────────────────────────────────────────
# Self-hosted PostgreSQL 15 — NO managed services allowed
DATABASE_URL=postgresql://coreinventory_user:your_password@localhost:5432/coreinventory_db

# ─── AUTH ────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# ─── OTP / EMAIL (self-hosted SMTP, no SendGrid/Mailgun) ─
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@coreinventory.local

# ─── APP ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
